{
    "swagger": "2.0",
    "info": {
        "description": "A RESTful Web API for managing Kronox web resources and schedules",
        "title": "Kronox API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://www.swagger.io/support",
            "email": "support@swagger.io"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:5055",
    "basePath": "/api/v1",
    "paths": {
        "/programmes": {
            "get": {
                "description": "Search for academic programmes across multiple school URLs using a search query",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "programmes"
                ],
                "summary": "Search for programmes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Search query for programmes",
                        "name": "q",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "\"hkr\"",
                        "description": "School that request pertains to",
                        "name": "school",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "example": 0,
                        "description": "Index of the school URL to use",
                        "name": "url_index",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of programmes matching search criteria",
                        "schema": {
                            "$ref": "#/definitions/handlers.ProgrammesResponse"
                        }
                    },
                    "400": {
                        "description": "Search query required or invalid url_index",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Failed to fetch or parse programmes",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/schedules": {
            "get": {
                "description": "Retrieve schedule events for one or more schedule IDs with optional language and date filtering",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "schedules"
                ],
                "summary": "Get schedule events",
                "parameters": [
                    {
                        "type": "string",
                        "example": "\"schedule1,schedule2,schedule3\"",
                        "description": "Comma-separated list of schedule IDs",
                        "name": "schedule_ids",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "format": "date",
                        "example": "\"2024-01-15\"",
                        "description": "Start date for filtering events (YYYY-MM-DD format)",
                        "name": "start_date",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "example": "\"hkr\"",
                        "description": "School that request pertains to",
                        "name": "school",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "example": 0,
                        "description": "Index of the school URL to use",
                        "name": "url_index",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of schedule events",
                        "schema": {
                            "$ref": "#/definitions/handlers.ScheduleEventsResponse"
                        }
                    },
                    "400": {
                        "description": "Missing required parameters, invalid date format, or invalid url_index",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Failed to fetch or parse schedule data",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.ErrorResponse": {
            "description": "Error response structure",
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "Invalid request"
                }
            }
        },
        "handlers.Programme": {
            "description": "Academic programme information",
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "CS101"
                },
                "credits": {
                    "type": "integer",
                    "example": 180
                },
                "description": {
                    "type": "string",
                    "example": "Bachelor's degree in Computer Science"
                },
                "id": {
                    "type": "string",
                    "example": "prog_123"
                },
                "name": {
                    "type": "string",
                    "example": "Computer Science"
                }
            }
        },
        "handlers.ProgrammesResponse": {
            "description": "Response containing list of programmes matching the search criteria",
            "type": "object",
            "properties": {
                "programmes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handlers.Programme"
                    }
                }
            }
        },
        "handlers.ScheduleEvent": {
            "description": "Schedule event information",
            "type": "object",
            "properties": {
                "courseCode": {
                    "type": "string",
                    "example": "MATH101"
                },
                "endTime": {
                    "type": "string",
                    "example": "2024-01-15T10:30:00Z"
                },
                "id": {
                    "type": "string",
                    "example": "evt_123"
                },
                "instructor": {
                    "type": "string",
                    "example": "Dr. Smith"
                },
                "location": {
                    "type": "string",
                    "example": "Room A101"
                },
                "startTime": {
                    "type": "string",
                    "example": "2024-01-15T09:00:00Z"
                },
                "title": {
                    "type": "string",
                    "example": "Math Lecture"
                }
            }
        },
        "handlers.ScheduleEventsResponse": {
            "description": "Response containing list of schedule events parsed from XML",
            "type": "object",
            "properties": {
                "events": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handlers.ScheduleEvent"
                    }
                }
            }
        }
    }
}